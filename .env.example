CLIENT_NAME='auto-build-test'

# Hostname for the WordPress container (no scheme). Browser URL is WP_HOME.
DOCKER_HOSTNAME='auto-build-test.ssl.localhost'

WP_ENV='development'
WP_HOME='https://auto-build-test.ssl.localhost'
WP_SITEURL="${WP_HOME}/wp"

# WP Engine staging/production (set in the WPE environment or .env on the server):
# WP_HOME='https://talldevstg.wpenginepowered.com'
# WP_SITEURL='https://talldevstg.wpenginepowered.com'
# Do not use "${WP_HOME}/wp" on WPE — core and content are served from the site root.
# PWP_NAME='talldevstg'
# Files still live in web/app/ and web/wp/ — only public URLs differ from local Bedrock.

WP_THEME_PATH='web/app/themes/ai-dev'

BE_MEDIA_FROM_PRODUCTION_URL=''

DB_PREFIX='wp_'
DB_NAME='wp_auto_build_test'
DB_USER='auto_build_test'
DB_PASSWORD='changeme'
DB_HOST='db'
DB_ROOT_PASSWORD='wordpressroot'
DB_RANDOM_ROOT_PASSWORD='1'
DB_EXTERNAL_PORT=3310

# Optional — only used by scripts/db-import.sh
# FORCE_DB_IMPORT=1   # always import dump.sql
# SKIP_DB_IMPORT=1    # never import

# WP Engine local stubs (when running WPE mu-plugins locally).
PWP_NAME='auto-build-test-local'
WPE_APIKEY='local-dev-not-used'

# Generate keys: https://roots.io/salts.html
AUTH_KEY='generateme'
SECURE_AUTH_KEY='generateme'
LOGGED_IN_KEY='generateme'
NONCE_KEY='generateme'
AUTH_SALT='generateme'
SECURE_AUTH_SALT='generateme'
LOGGED_IN_SALT='generateme'
NONCE_SALT='generateme'
